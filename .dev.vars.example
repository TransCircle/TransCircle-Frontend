# Copy to .dev.vars and fill in values
# .dev.vars is gitignored — never commit real secrets

SESSION_SECRET=change-me-to-random-64-chars
TEMP_ADMIN_TOKEN=change-me-to-a-strong-temp-token

# GitHub OAuth (optional for initial deploy — admin can use TEMP_ADMIN_TOKEN)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ORG=TransCircle

# X OAuth (optional)
X_CLIENT_ID=
X_CLIENT_SECRET=

# Story repo auto-build (optional — needs GitHub PAT)
STORY_REPO_TOKEN=

# Cloudflare Turnstile (optional — free CAPTCHA)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
