# TransCircle 故事站前端 环境变量（见 src/config.ts）
# 复制为 .env（本地）/ .env.production（生产）后填值。
# 注意：后端 API 基址不在这里配——它在 src/config.ts 写死为相对路径 /v1（同源），
#       本地开发由 vite.config.ts 的 server.proxy 把 /v1 转发到 http://localhost:1145。
# Vite 只暴露 VITE_ 前缀变量给前端，勿放机密。

# 登出后跳转目标。留空：生产用 https://story.transcircle.org，dev 用 /
VITE_LOGOUT_REDIRECT=

# TransCircle Pass 账户中心（导航站门户）基址。故事站把改密/两步验证/通行密钥/登录设备/注销
# 等安全操作深链到这里。
# - 生产留空即用默认 https://transcircle.org/account
# - 本地四件套联调请填本地门户：
#   VITE_PASS_ACCOUNT_BASE=http://localhost:5174/account
VITE_PASS_ACCOUNT_BASE=

# 图片/静态资源基址（拼接相对路径如 avatarUrl）
# - 生产：https://api.transcircle.org/pass
# - 本地留空则使用默认值
VITE_IMAGE_BASE=
